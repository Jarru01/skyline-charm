# /etc/skyline/skyline.yaml
# Managed by the Juju skyline charm — do not edit by hand.
# Changes will be overwritten on every `juju config` change or charm upgrade.

default:
  access_token_expire: 3600
  access_token_renew: 1800
  cafile: ''
  cors_allow_origins: []
  database_url: {{ database_url }}
  debug: {{ debug | lower }}
  log_dir: {{ skyline_log_dir }}
  log_file: skyline.log
  policy_file_path: {{ skyline_conf_dir }}/policy
  policy_file_suffix: policy.yaml
  prometheus_basic_auth_password: '{{ prometheus_basic_auth_password }}'
  prometheus_basic_auth_user: '{{ prometheus_basic_auth_user }}'
  prometheus_enable_basic_auth: {{ prometheus_enable_basic_auth | lower }}
  prometheus_endpoint: '{{ prometheus_endpoint }}'
  secret_key: {{ secret_key }}
  session_name: session
  ssl_enabled: {{ ssl_enabled | lower }}

openstack:
  base_domains:
    - heat_user_domain
  default_region: {{ default_region }}
  enforce_new_defaults: {{ enforce_new_defaults | lower }}
  extension_mapping:
    floating-ip-port-forwarding: neutron_port_forwarding
    fwaas_v2: neutron_firewall
    qos: neutron_qos
    vpnaas: neutron_vpn
  interface_type: {{ interface_type }}
  keystone_url: {{ keystone_url }}
  nginx_prefix: /api/openstack
  reclaim_instance_interval: {{ reclaim_instance_interval }}
  service_mapping:
    baremetal: ironic
    compute: nova
    container: zun
    container-infra: magnum
    database: trove
    dns: designate
    identity: keystone
    image: glance
    instance-ha: masakari
    key-manager: barbican
    load-balancer: octavia
    network: neutron
    object-store: swift
    orchestration: heat
    placement: placement
    sharev2: manilav2
    volumev3: cinder
  sso_enabled: {{ sso_enabled | lower }}
  sso_protocols:
    - openid
  sso_region: {{ sso_region }}
  system_admin_roles:
    - admin
    - system_admin
  system_project: {{ system_project }}
  system_project_domain: {{ system_project_domain }}
  system_reader_roles:
    - system_reader
  system_user_domain: {{ system_user_domain }}
  system_user_name: {{ system_user_name }}
  system_user_password: {{ system_user_password }}

setting:
  base_settings:
    - flavor_families
    - gpu_models
    - usb_models
  flavor_families:
    - architecture: x86_architecture
      categories:
        - name: general_purpose
          properties: []
        - name: compute_optimized
          properties: []
        - name: memory_optimized
          properties: []
        - name: high_clock_speed
          properties: []
    - architecture: heterogeneous_computing
      categories:
        - name: compute_optimized_type_with_gpu
          properties: []
        - name: visualization_compute_optimized_type_with_gpu
          properties: []
  gpu_models:
    - nvidia_t4
  usb_models:
    - usb_c
