# /etc/nginx/nginx.conf
# Managed by the Juju skyline charm — do not edit by hand.
#
# Design notes:
#   - gunicorn binds to 127.0.0.1:28000 (loopback only)
#   - nginx is the sole public listener on port {{ listen_port }}
#   - Static React assets are served directly from the skyline_console package
#   - /api/openstack/* is proxied to gunicorn

user www-data;
worker_processes auto;
pid /run/nginx.pid;
include /etc/nginx/modules-enabled/*.conf;

events {
    worker_connections 1024;
}

http {
    sendfile on;
    tcp_nopush on;
    types_hash_max_size 2048;

    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    # Logging
    access_log /var/log/nginx/access.log;
    error_log  /var/log/nginx/error.log;

    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types
        text/plain text/css text/xml text/javascript
        application/json application/javascript application/xml+rss
        application/atom+xml image/svg+xml;

    # ── Upstream — skyline-apiserver via gunicorn ───────────────────────
    upstream skyline_apiserver {
        server 127.0.0.1:28000 fail_timeout=0;
    }

    # ── Virtual server ──────────────────────────────────────────────────
    server {
        listen {{ listen_port }} default_server;
        listen [::]:{{ listen_port }} default_server;

        server_name _;

        access_log /var/log/nginx/skyline_access.log;
        error_log  /var/log/nginx/skyline_error.log;

        # Static assets from the installed skyline_console Python package
        root {{ static_path }};
        index index.html;

        # ── API proxy ───────────────────────────────────────────────────
        # All /api/openstack/* requests are forwarded to gunicorn.
        # The trailing slash in proxy_pass strips the location prefix,
        # which is what skyline-apiserver expects.
        location /api/openstack {
            proxy_pass         http://skyline_apiserver;
            proxy_http_version 1.1;

            proxy_set_header   Host              $http_host;
            proxy_set_header   X-Real-IP         $remote_addr;
            proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header   X-Forwarded-Proto $scheme;
            proxy_set_header   Upgrade           $http_upgrade;
            proxy_set_header   Connection        "upgrade";

            proxy_read_timeout    300;
            proxy_connect_timeout 300;
            proxy_send_timeout    300;

            # Increase buffer sizes for large API responses
            proxy_buffer_size          128k;
            proxy_buffers              4 256k;
            proxy_busy_buffers_size    256k;
        }

        # ── React SPA — catch-all ───────────────────────────────────────
        # All non-API requests serve the React app entry point.
        # The React router handles client-side navigation.
        location / {
            try_files $uri $uri/ /index.html;
        }

        # ── Static asset caching ────────────────────────────────────────
        # Webpack output files include a content hash, so they are
        # safe to cache for a long time.
        location ~* \.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)$ {
            expires 30d;
            add_header Cache-Control "public, immutable";
            try_files $uri =404;
        }
    }
}
